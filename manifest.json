{
  "manifest_version": 3,
  "name": "Teams Keep Active",
  "version": "1.1.0",
  "description": "Prevents Microsoft Teams from setting your status to Away.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Teams Keep Active"
  },
  "content_scripts": [
    {
      "matches": ["https://teams.microsoft.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
